        setclipboard(table.concat(DebugLogs, "\n"))
    end
end

local function StartEntity(data)
    task.spawn(function()

        repeat
            RunService.Heartbeat:Wait()
        until GameStarted


        local seed = Hash(game.JobId) + data.Offset
        local lastSlot = -1

        while true do

            -- pause timer
            while _G.PauseCooldown do
                RunService.Heartbeat:Wait()
            end


            local now = (workspace:GetServerTimeNow() - START_TIME) - _G.TotalPausedTime


            -- slot dựa theo MaxTime để tạo khoảng thời gian
            local slot = math.floor(now / data.MaxTime)


            -- tránh xử lý lại slot cũ
            if slot == lastSlot then
                RunService.Heartbeat:Wait()
                continue
            end


            local slotRng = Random.new(seed + slot)


            -- thời điểm spawn riêng của slot này
            local spawnDelay = slotRng:NextNumber(data.MinTime, data.MaxTime)
            local spawnTime = (slot * data.MaxTime) + spawnDelay


            -- đợi tới đúng thời điểm
            repeat
                RunService.Heartbeat:Wait()

                now = (workspace:GetServerTimeNow() - START_TIME) - _G.TotalPausedTime

            until now >= spawnTime and not _G.PauseCooldown


            lastSlot = slot


            -- chance
            local chanceRng = Random.new(seed + slot + 99999)

            if chanceRng:NextInteger(1,100) <= data.Chance then

                local doors = LocalPlayer:FindFirstChild("PlayerFolder") 
                    and LocalPlayer.PlayerFolder:FindFirstChild("DoorsOpened")


                if doors and doors.Value > 0 then


                    -- Oblivion không cần chờ cửa
                    if data.Name == "Oblivion" then

                        TrySpawn(data)


                    else

                        if not PendingEntities[data.Name] then

                            PendingEntities[data.Name] = true

                            local oldValue = doors.Value


                            task.spawn(function()

                                while PendingEntities[data.Name] do

                                    RunService.Heartbeat:Wait()


                                    if doors.Value > oldValue then

                                        PendingEntities[data.Name] = nil

                                        TrySpawn(data)

                                        break
                                    end
                                end

                            end)

                        end
                    end
                end
            end
        end
    end)
end

