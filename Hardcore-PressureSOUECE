local function TrySpawn(data)

    if data.PauseCooldownWhenOn then
        _G.PauseCooldown = true
        _G.PauseStarted = workspace:GetServerTimeNow()
    end

    task.spawn(function()
        local success, result = pcall(function()

    local File = "Entity_" .. data.Name:gsub("%s+", "_") .. ".lua"

    local Source

    if isfile(File) then
        Source = readfile(File)
    else
        Source = game:HttpGet(data.Url)
        writefile(File, Source)
    end

    return loadstring(Source)()

end)

        if not success then
            warn("Spawn Error: "..tostring(result))
        end

        if data.PauseCooldownWhenOn then
            _G.TotalPausedTime += workspace:GetServerTimeNow() - _G.PauseStarted
            _G.PauseCooldown = false
        end
    end)
end

