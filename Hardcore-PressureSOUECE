local function Hash(str)
    local h = 0
    for i = 1, #str do
        h = (h * 31 + str:byte(i)) % 2147483647
    end
    return h
end

local remote = game.ReplicatedStorage.Events.Subtitles

local function Subtitle(text, duration)
    local conn = getconnections(remote.OnClientEvent)[1]
    if not conn then
        warn("No connection found!")
        return
    end

    local ok, err = pcall(conn.Function, text, duration)
    print(ok, err)
end

