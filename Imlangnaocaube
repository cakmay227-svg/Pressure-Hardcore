local SoundCache = {}

local function GitAud(soundlink, filename)
	if SoundCache[filename] then
		return SoundCache[filename]
	end

	local file = filename..".mp3"

	if not isfile(file) then
		writefile(file, game:HttpGet(soundlink))
	end

	local asset = (getcustomasset or getsynasset)(file)

	SoundCache[filename] = asset

	return asset
end

