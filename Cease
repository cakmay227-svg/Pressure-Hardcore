local CachedSounds = {}

-- HÃ m táº£i Ã¢m thanh báº¥t Ä‘á»“ng bá»™ Ä‘á»ƒ trÃ¡nh ngháº½n luá»“ng
local function PreloadSound(soundlink, filename)
    task.spawn(function()
        local url = soundlink
        local FileName = filename
        if not isfile(FileName..".mp3") then
            writefile(FileName..".mp3", game:HttpGet(url))
        end
        CachedSounds[filename] = (getcustomasset or getsynasset)(FileName..".mp3")
    end)
end

