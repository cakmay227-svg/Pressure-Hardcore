local function cleanAndColorModel(model, targetColor, anchor)
    for _, child in pairs(model:GetDescendants()) do
        if child:IsA("ParticleEmitter") then
            child.Color = ColorSequence.new(targetColor)
            child.Parent = anchor 
        elseif child:IsA("Light") then
            child:Destroy() -- ÄÃ£ xÃ³a PointLight
        end
    end

    for _, child in pairs(model:GetDescendants()) do
        if child:IsA("BasePart") or child:IsA("MeshPart") then
            child:Destroy()
        end
    end
end

