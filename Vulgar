                        if obj.Parent then obj:PivotTo(newCFrame) end
                    end)
                    local tween = TweenService:Create(cframeValue, tweenInfo, {Value = targetCFrame})
                    tween:Play()
                    tween.Completed:Connect(function() cframeValue:Destroy() end)
                else
                    local tween = TweenService:Create(obj, tweenInfo, {CFrame = targetCFrame})
                    tween:Play()
                end
                
                task.delay(MODEL_LIFETIME, function()
                    if obj and obj.Parent then
                        local currentCF = obj:IsA("Model") and obj:GetPivot() or obj.CFrame
                        fadeOutAndDestroy(obj, currentCF)
                    end
                end)
            end
        end
        task.wait(SPAWN_COOLDOWN)
    end
end)


