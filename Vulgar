-- Cáº¥u hÃ¬nh Nhuá»™m Äá» PhÃ²ng báº±ng Tween 2 GiÃ¢y mÆ°á»£t mÃ 
local ConfigRedRoom = {
    TargetColor = Color3.fromRGB(200, 0, 0), -- MÃ u Ä‘á» rá»±c
    TweenTime = 2.0,                         -- ÄÃ£ chá»‰nh thÃ nh 2.0 giÃ¢y Ä‘á»ƒ chuyá»ƒn mÃ u mÆ°á»£t mÃ  hÆ¡n
}
local tweenInfoRedRoom = TweenInfo.new(ConfigRedRoom.TweenTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function turnCurrentRoomRedOnlyOnce()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local rootPart = character:WaitForChild("HumanoidRootPart", 10)
    if not rootPart then return end

    local currentRoom = nil
    local Rooms = workspace.GameplayFolder:FindFirstChild("Rooms") or workspace.GameplayFolder.Rooms

    -- QuÃ©t va cháº¡m dÆ°á»›i chÃ¢n tÃ¬m phÃ²ng trÆ°á»›c
    local touchingParts = workspace:GetPartsInPart(rootPart)
    for i = 1, #touchingParts do
        local current = touchingParts[i]
        while current and current.Parent do
            if current.Parent == Rooms and current:IsA("Model") then
                currentRoom = current
                break
            end
            current = current.Parent
        end
        if currentRoom then break end
    end

    -- Báº¯n tia Raycast xuá»‘ng dÆ°á»›i Ä‘á»ƒ dá»± phÃ²ng
    if not currentRoom then
        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        raycastParams.FilterDescendantsInstances = {character}
        local rayResult = workspace:Raycast(rootPart.Position, Vector3.new(0, -20, 0), raycastParams)
        
        if rayResult and rayResult.Instance then
            local current = rayResult.Instance
            while current and current.Parent do
                if current.Parent == Rooms and current:IsA("Model") then
                    currentRoom = current
                    break
                end
                current = current.Parent
            end
        end
    end

    -- Tiáº¿n hÃ nh nhuá»™m Ä‘á» phÃ²ng báº±ng Tween 2 giÃ¢y
    if currentRoom then
        local descendants = currentRoom:GetDescendants()
        for i = 1, #descendants do
            local obj = descendants[i]
            
            if obj:IsA("Light") then
                local path = obj:GetFullName()
                if path:find("%.Lights") or path:find("neon") or path:find("nec") then
                    obj.Enabled = true
                    TweenService:Create(obj, tweenInfoRedRoom, {Color = ConfigRedRoom.TargetColor}):Play()
                end
            elseif obj:IsA("MeshPart") or obj:IsA("BasePart") then
                local nameLower = obj.Name:lower()
                if nameLower == "neon" or nameLower == "smallneon" or nameLower == "nec" then
                    obj.Material = Enum.Material.Neon
                    TweenService:Create(obj, tweenInfoRedRoom, {Color = ConfigRedRoom.TargetColor}):Play()
                end
            end
        end
    end
end

