-- Báº£ng quáº£n lÃ½ thá»i gian há»“i chiÃªu nháº­n sÃ¡t thÆ°Æ¡ng cá»§a ngÆ°á»i chÆ¡i
local damageCooldowns = {}

-- HÃ m xá»­ lÃ½ gÃ¢y sÃ¡t thÆ°Æ¡ng tá»« phÃ­a Client lÃªn Server
local function dealDamageToPlayer(player)
    if damageCooldowns[player] and tick() - damageCooldowns[player] < 0.5 then return end
    damageCooldowns[player] = tick()

    local damageRemote = ReplicatedStorage:FindFirstChild("LocalDamage", true) or ReplicatedStorage:FindFirstChild("ChangeHealth", true)
    if damageRemote and damageRemote:IsA("RemoteEvent") then
        damageRemote:FireServer(DAMAGE_AMOUNT, "SittingItOut", 1, nil)
        damageRemote:FireServer("Damage", DAMAGE_AMOUNT)
    end
end

-- HÃ m táº£i Asset báº±ng ID
local function loadAsset()
    local success, objects = pcall(function()
        return game:GetObjects("rbxassetid://" .. ASSET_ID)
    end)
    if success and objects and #objects > 0 then
        return objects[1]
    else
        warn("KhÃ´ng thá»ƒ load Ä‘Æ°á»£c ID báº±ng Executor: " .. tostring(ASSET_ID))
        return nil
    end
end

-- HÃ m cáº¥u hÃ¬nh dung nham, phÃ³ng to, táº¯t va cháº¡m, thÃªm Ã¡nh sÃ¡ng & gÃ¢y sÃ¡t thÆ°Æ¡ng
local function modifyToLava(obj)
    local descendants = obj:GetDescendants()
    table.insert(descendants, obj)

    local mainPart = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")

    for _, descendant in ipairs(descendants) do
        if descendant:IsA("BasePart") or descendant:IsA("MeshPart") then
            descendant.CanCollide = false 
            descendant.Color = Color3.fromRGB(240, 70, 0) 
            descendant.Material = Enum.Material.CrackedLava
            descendant.Size = descendant.Size * SIZE_MULTIPLIER
            
            -- Láº¯ng nghe sá»± kiá»‡n va cháº¡m Ä‘á»ƒ trá»« mÃ¡u
            descendant.Touched:Connect(function(hit)
                local character = hit.Parent
                local player = Players:GetPlayerFromCharacter(character)
                if player and character:FindFirstChildOfClass("Humanoid") and character.Humanoid.Health > 0 then
                    dealDamageToPlayer(player)
                end
            end)
        elseif descendant:IsA("SpecialMesh") then
            descendant.VertexColor = Vector3.new(1, 0.3, 0)
            descendant.Scale = descendant.Scale * SIZE_MULTIPLIER
        end
    end

    -- Táº¡o PointLight mÃ u Ä‘á» gáº¯n vÃ o váº­t thá»ƒ
    if mainPart then
        local light = Instance.new("PointLight")
        light.Name = "LavaLight"
        light.Color = Color3.fromRGB(255, 0, 0)
        light.Range = 5
        light.Brightness = 1.5
        light.Shadows = false
        light.Parent = mainPart
    end
end

-- HÃ m xá»­ lÃ½ hiá»‡u á»©ng biáº¿n máº¥t (Fade Out vÃ  ChÃ¬m xuá»‘ng)
local function fadeOutAndDestroy(obj, currentCFrame)
    local descendants = obj:GetDescendants()
    table.insert(descendants, obj)
    
    local fadeTime = 1.0
    local tweenInfo = TweenInfo.new(fadeTime, Enum.EasingStyle.Cubic, Enum.EasingDirection.In)
    local sinkCFrame = currentCFrame - Vector3.new(0, 5, 0)
    
    if obj:IsA("Model") then
        local cframeValue = Instance.new("CFrameValue")
        cframeValue.Value = currentCFrame
        cframeValue.Changed:Connect(function(newCFrame)
            if obj.Parent then obj:PivotTo(newCFrame) end
        end)
        local moveTween = TweenService:Create(cframeValue, tweenInfo, {Value = sinkCFrame})
        moveTween:Play()
        moveTween.Completed:Connect(function() cframeValue:Destroy() end)
    else
        local moveTween = TweenService:Create(obj, tweenInfo, {CFrame = sinkCFrame})
        moveTween:Play()
    end
    
    for _, descendant in ipairs(descendants) do
        if descendant:IsA("BasePart") or descendant:IsA("MeshPart") then
            local fadeTween = TweenService:Create(descendant, tweenInfo, {Transparency = 1})
            fadeTween:Play()
        elseif descendant:IsA("PointLight") then
            local lightTween = TweenService:Create(descendant, tweenInfo, {Brightness = 0})
            lightTween:Play()
        end
    end
    
    task.wait(fadeTime)
    obj:Destroy()
end

-- VÃ²ng láº·p chÃ­nh xá»­ lÃ½ Spawn Lava theo thá»±c thá»ƒ Vulgar
task.spawn(function()
    while true do
        local entityRoot = nil
        local vulgarModel = workspace:FindFirstChild("Vulgar")
        
        if vulgarModel then
