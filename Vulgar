local ASSET_ID = 15217311499
local SPAWN_COOLDOWN = 0.05   -- Tá»‘c Ä‘á»™ táº¡o gai (0.05 giÃ¢y/cÃ¡i)
local MODEL_LIFETIME = 10     -- Gai tá»“n táº¡i trong 10 giÃ¢y
local SIZE_MULTIPLIER = 2.0   -- Tá»‰ lá»‡ phÃ³ng to váº­t thá»ƒ (gáº¥p 2 láº§n gá»‘c)
local DAMAGE_AMOUNT = 5       -- SÃ¡t thÆ°Æ¡ng khi cháº¡m vÃ o gai

local Players = game:GetService("Players")
