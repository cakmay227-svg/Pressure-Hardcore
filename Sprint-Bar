local Config = {
    MaxStamina = 100,
    CurrentStamina = 100,
    IsSprinting = false,
    Exhausted = false,
    Tired = false,
    TimeSinceStopped = 0,
    
    NormalSpeed = 13,   
    SprintSpeed = 21,   
    TiredSpeed = 9,     
    
    SavedNormalFOV = camera.FieldOfView, 
    FOVIncrease = 15,                     
}

local humanoid = nil
local rootPart = nil
local fovTween = nil
local BaseGameSpeed = 16
local AnimationSpeedMultiplier = 1.5

local function updatePOV(targetFOV)
    if fovTween then fovTween:Cancel() end
    fovTween = TweenService:Create(camera, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        FieldOfView = targetFOV
    })
    fovTween:Play()
end

local function UpdateAnimationSpeed(multiplier)
	if not humanoid then
		return
	end

	local animator = humanoid:FindFirstChildOfClass("Animator")
	if not animator then
		return
	end

	for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
		track:AdjustSpeed(multiplier)
	end
end

local function updateStaminaUI(targetStamina)
    local max = Config.MaxStamina
    local current = math.clamp(targetStamina, 0, max)
    Config.CurrentStamina = current
    
    local v9 = (max - current) / 20
    local v10 = math.floor(v9)
    local v11 = (max - current - v10 * 20) / 5
    local v12 = math.floor(v11)
    
    if staminaImageLabel then
        staminaImageLabel.ImageRectOffset = Vector2.new(v12 * 205, v10 * 205)
    end
    
    -- [UPDATE] Äá»”I MÃ€U KHI Sá»¬ Dá»¤NG: Giáº£m dáº§n tá»« MÃ€U Gá»C vá» mÃ u Äá»Ž Tá»I / XÃM KHÃ”
    local targetColor = Color3.fromRGB(130, 35, 35):Lerp(originalHealthColor, current / max)
    
    if not Config.Exhausted then
        if staminaImageLabel then staminaImageLabel.ImageColor3 = targetColor end
        if staminaSkull then staminaSkull.ImageColor3 = targetColor end
        if customImageLabel then customImageLabel.ImageColor3 = targetColor end
    end
    
    if current <= 0 then
        Config.Exhausted = true
        -- Khi cáº¡n sáº¡ch thá»ƒ lá»±c, Ã©p háº³n sang mÃ u xÃ¡m má»‡t má»i
        local exhaustedColor = Color3.fromRGB(80, 80, 80)
        if staminaImageLabel then staminaImageLabel.ImageColor3 = exhaustedColor end
        if staminaSkull then staminaSkull.ImageColor3 = exhaustedColor end
        if customImageLabel then customImageLabel.ImageColor3 = exhaustedColor end
        
        if Config.IsSprinting then
            Config.IsSprinting = false
            UpdateAnimationSpeed(1)
            Config.TimeSinceStopped = tick()
            Config.Tired = true
            updatePOV(Config.SavedNormalFOV)
        end
    else
        if current > (max * 0.75) then
            Config.Exhausted = false
            if staminaImageLabel then staminaImageLabel.ImageColor3 = targetColor end
            if staminaSkull then staminaSkull.ImageColor3 = targetColor end
            if customImageLabel then customImageLabel.ImageColor3 = targetColor end
        end
    end
end

local function onCharacterAdded(char)
    humanoid = char:WaitForChild("Humanoid")
    rootPart = char:WaitForChild("HumanoidRootPart")
    
    BaseGameSpeed = humanoid.WalkSpeed

humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
    if not Config.IsSprinting then
        BaseGameSpeed = humanoid.WalkSpeed
    end
end)

    updateStaminaUI(Config.MaxStamina)
    
    humanoid:GetPropertyChangedSignal("MoveDirection"):Connect(function()
        if humanoid.MoveDirection.Magnitude == 0 and Config.IsSprinting then
            Config.IsSprinting = false
            UpdateAnimationSpeed(1)
            Config.TimeSinceStopped = tick()
            updatePOV(Config.SavedNormalFOV)
        end
    end)
end

if player.Character then onCharacterAdded(player.Character) end
player.CharacterAdded:Connect(onCharacterAdded)

local function StartSprint()
	if not Config.Exhausted and not Config.Tired and humanoid and humanoid.MoveDirection.Magnitude > 0 then
		Config.SavedNormalFOV = camera.FieldOfView
		Config.IsSprinting = true
		UpdateAnimationSpeed(AnimationSpeedMultiplier)
		updatePOV(Config.SavedNormalFOV + Config.FOVIncrease)
	end
end

local function StopSprint()
	if Config.IsSprinting then
		Config.IsSprinting = false
		UpdateAnimationSpeed(1)
		Config.TimeSinceStopped = tick()
		updatePOV(Config.SavedNormalFOV)
	end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed or not IsPC then
		return
	end

	if input.KeyCode == Enum.KeyCode.E then
		if Config.IsSprinting then
			StopSprint()
		else
			StartSprint()
		end
	end
end)

if mobileSprintButton then
	mobileSprintButton.MouseButton1Down:Connect(function()
		if Config.IsSprinting then
			StopSprint()
		else
			StartSprint()
		end
	end)
end

