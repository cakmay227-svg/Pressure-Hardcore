_G.EntitySpawnLock = _G.EntitySpawnLock or false

local function TrySpawn(url)
    -- Đã có entity khác đang spawn
    if _G.EntitySpawnLock then
        return false, "Another entity is already spawning."
    end

    -- Khóa
    _G.EntitySpawnLock = true

    local success, result = pcall(function()
        local source = game:HttpGet(url)
        return loadstring(source)()
    end)

    -- Mở khóa kể cả thành công hay thất bại
    _G.EntitySpawnLock = false

    if success then
        return true
    else
        warn("[Entity Spawn] Error:", result)
        return false, result
    end
end

