local function runFastJumpscare()
    local sound = loadSound(EntityConfig.Sound1)
    
    local gui = Instance.new("ScreenGui")
    local bgFrame = Instance.new("Frame")
    local faceLabel = Instance.new("ImageLabel")
    
    gui.Name = "FastJumpscareGui"
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    
    bgFrame.Name = "Background"
    bgFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    bgFrame.BorderSizePixel = 0
    bgFrame.Size = UDim2.new(1, 0, 1, 0)
    bgFrame.ZIndex = 999
    
    local screenY = gui.AbsoluteSize.Y > 0 and gui.AbsoluteSize.Y or 1080
    local startSize = screenY / 2
    
    faceLabel.Name = "Face"
    faceLabel.AnchorPoint = Vector2.new(0.5, 0.5)
    faceLabel.BackgroundTransparency = 1
    faceLabel.Position = UDim2.new(0.5, 0, 0.5, 0)
    faceLabel.ResampleMode = Enum.ResamplerMode.Pixelated
    faceLabel.Size = UDim2.new(0, startSize, 0, startSize)
    faceLabel.Image = EntityConfig.Image1
    
    faceLabel.Parent = bgFrame
    bgFrame.Parent = gui
    gui.Parent = CoreGui
    
    if EntityConfig.Flashing[1] then
        task.spawn(function()
            while gui.Parent do
                bgFrame.BackgroundColor3 = EntityConfig.Flashing[2]
                task.wait(0.03)
                bgFrame.BackgroundColor3 = Color3.new(0, 0, 0)
                task.wait(0.03)
            end
        end)
    end
    
    if EntityConfig.Shake then
        task.spawn(function()
            local originalPos = faceLabel.Position
            while gui.Parent do
                faceLabel.Position = originalPos + UDim2.new(0, math.random(-25, 25), 0, math.random(-25, 25))
                faceLabel.Rotation = math.random(-10, 10)
                task.wait()
            end
        end)
    end
    
    sound:Play()
    
    local tween = TweenService:Create(faceLabel, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, screenY * 3, 0, screenY * 3),
        ImageTransparency = 0.6
    })
    tween:Play()
    
    task.wait(1)
    
    gui:Destroy()
    sound:Destroy()
end

local TweenService = game:GetService("TweenService")
local cc = lighting.MainColorCorrection

local TOTAL_FLASHES = 18

for i = 1, TOTAL_FLASHES do
    local progress = (i - 1) / (TOTAL_FLASHES - 1)

    local flashSpeed = math.max(0.32 - (progress * 0.28), 0.04)
    local resetSpeed = math.max(0.68 - (progress * 0.62), 0.06)

    local currentMagnitude = 0.4 + (progress * 3.6)
    local currentRoughness = 5 + (progress * 13)
    shakeCamera("Explosion", currentMagnitude, currentRoughness)

    local redTween = TweenService:Create(cc, TweenInfo.new(flashSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        TintColor = Color3.fromRGB(255, 45, 45), 
        Contrast = 0.35,
        Saturation = -0.2
    })
    local normalTween = TweenService:Create(cc, TweenInfo.new(resetSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        TintColor = Color3.fromRGB(255, 255, 255), 
        Contrast = 0,
        Saturation = 0
    })

    redTween:Play()
    task.wait(flashSpeed)
    normalTween:Play()
    task.wait(resetSpeed) 
end

