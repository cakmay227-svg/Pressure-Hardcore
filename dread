--========================================================
-- RANDOM FLOOR POSITION
--========================================================

local RayParams = RaycastParams.new()
RayParams.FilterType = Enum.RaycastFilterType.Include
RayParams.FilterDescendantsInstances = {Model}

local function RandomPoint()
	local radius = 40

	local offset = Vector3.new(
		math.random(-radius, radius),
		50,
		math.random(-radius, radius)
	)

	local origin = HRP.Position + offset

	local result = workspace:Raycast(
		origin,
		Vector3.new(0, -150, 0),
		RayParams
	)

	if result then
		return result.Position + Vector3.new(0, Height / 2, 0)
	end

	return HRP.Position + Vector3.new(0, Height / 2, 0)
end

local Result = workspace:Raycast(
	HRP.Position + HRP.CFrame.LookVector * 15 + Vector3.new(0, 50, 0),
	Vector3.new(0, -150, 0),
	RayParams
)

if Result then
	Root.CFrame = CFrame.lookAt(
		Result.Position + Vector3.new(0, Height / 2, 0),
		HRP.Position
	)
end

